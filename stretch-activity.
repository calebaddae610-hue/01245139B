#include <iostream>
using namespace std; // Fixed duplicate "namespace" typo

int main() {
    // Changed to double to allow decimal outputs in division
    double a, b; 
    
    // Get user input
    cout << "Enter first number: ";
    cin >> a;
    cout << "Enter second number: ";
    cin >> b;
    
    // Perform operations
    cout << "Sum = " << a + b << "\n";
    cout << "Difference = " << a - b << "\n";
    cout << "Product = " << a * b << "\n";
    
    // Protect against division by zero
    if (b == 0) {
        cout << "Quotient = Error (Cannot divide by zero)\n";
    } else {
        cout << "Quotient = " << a / b << "\n";
    }
    
    return 0;
}
